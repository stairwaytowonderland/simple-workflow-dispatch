# https://github.com/github/gitignore/tree/main

# System files
# macOS - https://github.com/github/gitignore/blob/main/Global/macOS.gitignore
## macOS General
.DS_Store
__MACOSX/
.AppleDouble
.LSOverride
Icon[]

## macOS Thumbnails
._*

# Docker
## Logs
build.log*
*.swp

## Stores VSCode versions used for testing VSCode extensions
.vscode-test

# Terraform - https://github.com/github/gitignore/blob/main/Terraform.gitignore
## Local .terraform directories
.terraform/

## .tfstate files
*.tfstate
*.tfstate.*

## Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
# *.tfvars
*.auto.tfvars
*.tfvars.json

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

# Distribution / packaging
node_modules/
.npm/
.yarn/
.pnpm/
build/
dist/
downloads/
MANIFEST

## Environments
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# --------------------------------

# Project-specific ignores
*.bak
*.old
*.tmp
*.private
/.last
/.command

logs
*.log
out/
